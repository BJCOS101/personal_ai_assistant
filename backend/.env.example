# =================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# =================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# ------------------------------------------------------------------
# LLM Provider Configuration (Choose ONE)
# ------------------------------------------------------------------

# Option 1: Groq (cloud - free tier, fast, high quality)
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (fully offline - nothing leaves your machine)
# Requires Ollama installed & running locally (brew install ollama),
# and the model pulled once with: ollama pull llama3.1:8b
# No API key needed for this option.
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------
# Embedding Configuration (always local - no API key needed)
# ------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=personal_knowledge

# ------------------------------------------------------------------
# Document Storage
# ------------------------------------------------------------------
DOCUMENTS_DIRECTORY=./data/documents
MAX_UPLOAD_SIZE_MB=20

# ------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------
# LLM Settings
# ------------------------------------------------------------------
LLM_TEMPERATURE=0.0
MAX_TOKENS=1000
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Chunks scoring below this similarity (0.0 - 1.0) are dropped before
# reaching the AI, so it never answers from weak/off-topic matches.
RELEVANCE_THRESHOLD=0.3

ANONYMIZED_TELEMETRY=False